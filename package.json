{
  "name": "soouls",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --continue --filter=@soouls/backend --filter=@soouls/frontend --filter=@soouls/admin-dashboard",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check-types": "turbo run check-types",
    "knip": "knip",
    "prepare": "husky",
    "test": "bun test --pass-with-no-tests"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.7",
    "knip": "^5.88.1",
    "peakroute": "^0.6.0",
    "turbo": "^2.9.4",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": ["apps/*", "packages/*"],
  "resolutions": {
    "mime": "1.6.0"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.47.0",
    "lz-string": "^1.5.0",
    "next": "^16.2.2",
    "react-icons": "^5.6.0"
  }
}
