# Database Configuration
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_CLERK_FRONTEND_API=your-clerk-instance.clerk.accounts.dev

# Clerk Auth URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Core App URLs
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001
COMMAND_CENTER_URL=http://localhost:4000

# Background Notifications Queue (Redis)
REDIS_URL=
NOTIFICATION_WORKER_CONCURRENCY=10

# Transactional Email (Resend)
RESEND_API_KEY=
MESSAGING_FROM_EMAIL=
MESSAGING_FROM_NAME=Soouls
MESSAGING_REPLY_TO_EMAIL=

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Newsletter Sync
NEWSLETTER_SYNC_URL=
NEWSLETTER_SYNC_API_KEY=
NEWSLETTER_SYNC_AUDIENCE=

# SoulLabs Command Center Bootstrap
COMMAND_CENTER_BOOTSTRAP_SUPER_ADMINS=your-email@example.com

# Optional Legacy Messaging Admin Allow-list
MESSAGING_ADMIN_EMAILS=
MESSAGING_ADMIN_CLERK_IDS=

# Sentry Error Tracking
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# PostHog Product Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Cloudflare R2 Object Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=soouls-media
R2_PUBLIC_URL=

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Google Calendar OAuth2
# Create credentials at: https://console.cloud.google.com -> APIs & Services -> Credentials
# Required scopes: https://www.googleapis.com/auth/calendar.readonly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/google-calendar/callback
# Public URL the frontend Connect button hits to start the OAuth flow
NEXT_PUBLIC_GOOGLE_CALENDAR_OAUTH_URL=http://localhost:3000/google-calendar/connect

# Logging
LOG_LEVEL=info
NODE_ENV=development
