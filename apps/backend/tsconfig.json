{
  "extends": "@soouls/typescript-config/node.json",
  "compilerOptions": {
    "declaration": true,
    "removeComments": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "paths": {
      "@soouls/api/*": ["../../packages/api/src/*"],
      "@soouls/database/*": ["../../packages/database/src/*"],
      "@soouls/ai-engine/*": ["../../packages/ai-engine/src/*"]
    },
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
