{
  "name": "@soulcanvas/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "bun run --env-file=../../.env src/main.ts",
    "dev": "bun run --env-file=../../.env scripts/dev.ts",
    "start:debug": "bun run --env-file=../../.env --watch --inspect src/main.ts",
    "start:prod": "bun run --env-file=../../.env dist/main.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check-types": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.5",
    "@bull-board/nestjs": "^6.20.5",
    "@clerk/backend": "^1.19.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/websockets": "^11.1.16",
    "@react-email/components": "^1.0.9",
    "@react-email/render": "^2.0.4",
    "@soulcanvas/ai-engine": "*",
    "@soulcanvas/api": "*",
    "@soulcanvas/database": "*",
    "@soulcanvas/logic": "*",
    "@trpc/server": "^11.0.0-rc.710",
    "bullmq": "^5.71.0",
    "cron": "^4.3.5",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "luxon": "^3.7.0",
    "lz-string": "^1.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.1.13",
    "resend": "^6.9.3",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@soulcanvas/typescript-config": "*",
    "@types/bun": "latest",
    "@types/express": "^4.17.17",
    "@types/lz-string": "^1.5.0",
    "@types/node": "^20.3.1",
    "jest": "^29.5.0",
    "mime": "1.6.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.2"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
